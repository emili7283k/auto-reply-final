# ── Telegram API (from https://my.telegram.org/apps) ──
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# ── Bot Tokens (from @BotFather) ──
MAIN_BOT_TOKEN=your_main_bot_token_here
LOGGER_BOT_TOKEN=your_logger_bot_token_here

# ── Admin IDs (comma-separated Telegram user IDs) ──
ADMIN_IDS=123456789,987654321

# ── Database (Neon.tech PostgreSQL) ──
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Groq AI ──
GROQ_API_KEY=your_groq_api_key_here

# ── Channels & Links ──
UPDATES_CHANNEL=@Uzeron_AdsBot
COMMUNITY_GROUP=@Uzeron_Ads_support
SUPPORT_LINK=https://t.me/Uzeron_Ads_support
CONTACT_USERNAME=@Pandaysubscription
